# ---- Server ----
PORT=3001
NODE_ENV=production
CORS_ORIGIN=http://localhost:5173,http://localhost,https://smart-ndc-pro.local

# ---- Database ----
DATABASE_URL=postgresql://smartndc:smartndc@postgres:5432/smartndc?schema=public

# ---- JWT ----
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=24h

# ---- MinIO (S3-compatible object storage) ----
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=smart-ndc
MINIO_USE_SSL=false

# ---- Firebase Cloud Messaging (push notifications) ----
# Path to service account JSON inside the container
FCM_CREDENTIAL_PATH=/run/secrets/fcm-service-account.json
# Or paste base64 of the JSON (optional alternative)
FCM_CREDENTIAL_BASE64=

# ---- Redis (optional, for caching/sessions) ----
REDIS_URL=redis://redis:6379

# ---- Backup (used by docker/backup.sh) ----
BACKUP_DIR=/backups
BACKUP_RETENTION_DAYS=30