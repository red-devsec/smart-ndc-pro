# ---- API ----
# URL the web app uses to reach the backend (same origin in prod, proxied by Nginx)
VITE_API_URL=/api
# Absolute URL for MinIO public downloads (for files served directly to the browser)
VITE_MINIO_PUBLIC_URL=http://localhost:9000

# ---- Realtime ----
VITE_SOCKET_URL=/
VITE_SOCKET_PATH=/socket.io

# ---- Feature flags ----
VITE_ENABLE_CAMERA_SCAN=true
VITE_ENABLE_OFFLINE_QUEUE=true
VITE_ENABLE_DASHBOARD_PDF_EXPORT=true